# ---------------------------------------------------------------------------
# Local development (.env, used by ``docker compose up`` and bare ``manage.py``)
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=backend.settings
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# SQLite is the default. Override the file location with ``DJANGO_DB_PATH``.
# DJANGO_DB_PATH=/data/db.sqlite3

# Static media files (avatar uploads) under /media/ when DEBUG is off.
SERVE_MEDIA=1

# Optional: public URL used in password-reset emails and other links.
# REFLEX_DJANGO_SITE_ORIGIN=https://your-domain.example

# Optional: pin a known-good Vite when Reflex ships one with a frontend
# regression. See reflex-django/docs/settings_reference.md#frontend-toolchain.
# REFLEX_DJANGO_VITE_VERSION=7.3.3

# ---------------------------------------------------------------------------
# Production (.env loaded by ``docker compose -f docker-compose.prod.yml``)
# ---------------------------------------------------------------------------
# DJANGO_DEBUG=0
# DJANGO_SECRET_KEY=                       # REQUIRED — generate with ``python -c "import secrets; print(secrets.token_urlsafe(64))"``
# DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com
# RUN_COLLECTSTATIC=0                       # SPA is staged into staticfiles at image build time
# UVICORN_WORKERS=4
# PUBLIC_PORT=8000

# Database. Defaults to SQLite on a Docker volume. Flip to Postgres for
# multi-worker production:
# DJANGO_DB_ENGINE=postgresql
# DJANGO_DB_NAME=rxdjango
# DJANGO_DB_USER=rxdjango
# DJANGO_DB_PASSWORD=replace-me
# DJANGO_DB_HOST=db
# DJANGO_DB_PORT=5432

# Shared Reflex state manager across workers/replicas (required when running
# with more than one uvicorn worker behind a load balancer without sticky
# sessions). Compose service name when the ``redis`` profile is enabled.
# REDIS_URL=redis://redis:6379/0
