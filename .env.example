# Shared Django / Reflex settings
DJANGO_SETTINGS_MODULE=backend.settings
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000,http://localhost:8080,http://127.0.0.1:8080
DJANGO_DB_PATH=/data/db.sqlite3
SERVE_MEDIA=1

# Production-only (set in .env when using docker-compose.prod.yml)
# DJANGO_DEBUG=0
# RUN_COLLECTSTATIC=1

# Optional: public URL for password-reset emails
# REFLEX_DJANGO_SITE_ORIGIN=https://your-domain.example
